generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  name           String
  email          String          @unique
  passwordHash   String
  role           UserRole        @default(WRITER)
  status         UserStatus      @default(ACTIVE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  profile        Profile?
  messages       Message[]
  memberships    ChatMember[]
  announcements  Announcement[]
  approvedBy     AccountRequest[] @relation("ApprovedBy")
}

model Profile {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  characterName String?
  faction       String?
  styleNotes    String?
  avatarUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AccountRequest {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  passwordHash String
  status       RequestStatus @default(PENDING)
  approvedById Int?
  approvedBy   User?         @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Chat {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  createdById Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     ChatMember[]
  messages    Message[]
}

model ChatMember {
  id        Int      @id @default(autoincrement())
  chatId     Int
  userId     Int
  createdAt  DateTime @default(now())
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
}

model Message {
  id        Int      @id @default(autoincrement())
  chatId    Int
  senderId  Int
  body      String
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  body        String
  createdById Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  WRITER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}
